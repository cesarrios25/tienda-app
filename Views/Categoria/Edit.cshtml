@model TiendaApp.Models.Categoria

@{ ViewData["Title"] = "Editar Categoría"; }
<div class="page-wrapper">
    <div class="page-header">
        <h2>Editar Categoría</h2>
    </div>
    <div class="form-wrapper">
        <form asp-action="Edit" asp-controller="Categoria" method="post">
            <input asp-for="IdCategoria" type="hidden" />
            <input asp-for="CreadoEn" type="hidden" />
            <div class="mb-3">
                <label asp-for="NombreCategoria" class="form-label"></label>
                <input asp-for="NombreCategoria" class="form-control" />
                <span asp-validation-for="NombreCategoria" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="DescripcionCategoria" class="form-label"></label>
                <textarea asp-for="DescripcionCategoria" class="form-control"></textarea>
            </div>
            <div class="mb-3 form-check">
                <input asp-for="Activo" class="form-check-input" />
                <label asp-for="Activo" class="form-check-label"></label>
            </div>
            <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
            <button type="submit" class="btn btn-primary">Guardar</button>
        </form>
    </div>
</div>