@model TiendaApp.Models.Producto
@{ ViewData["Title"] = "Nuevo Producto"; }

<div class="page-wrapper">
    <div class="page-header">
        <h2>Nuevo Producto</h2>
    </div>
    <div class="form-wrapper">
        <form asp-action="Create" method="post">
            <div class="form-section">
                <p class="form-section-title">Información básica</p>
                <div class="mb-3">
                    <label asp-for="NombreProducto" class="form-label">Nombre</label>
                    <input asp-for="NombreProducto" class="form-control" />
                    <span asp-validation-for="NombreProducto" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="SKU" class="form-label">SKU</label>
                    <input asp-for="SKU" class="form-control" />
                    <span asp-validation-for="SKU" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="DescripcionProducto" class="form-label">Descripción</label>
                    <textarea asp-for="DescripcionProducto" class="form-control" rows="3"></textarea>
                </div>
                <div class="mb-3">
                    <label asp-for="Marca" class="form-label">Marca</label>
                    <input asp-for="Marca" class="form-control" />
                </div>
            </div>
            <div class="form-section">
                <p class="form-section-title">Precio y stock</p>
                <div class="row g-3 mb-3">
                    <div class="col-6">
                        <label asp-for="Precio" class="form-label">Precio</label>
                        <input asp-for="Precio" class="form-control" />
                        <span asp-validation-for="Precio" class="text-danger"></span>
                    </div>
                    <div class="col-6">
                        <label asp-for="DescuentoPrecio" class="form-label">Precio con descuento</label>
                        <input asp-for="DescuentoPrecio" class="form-control" />
                    </div>
                </div>
                <div class="row g-3">
                    <div class="col-6">
                        <label asp-for="IdCategoria" class="form-label">Categoría</label>
                        <select asp-for="IdCategoria" asp-items="ViewBag.CategoryId" class="form-select">
                            <option value="">-- Selecciona --</option>
                        </select>
                        <span asp-validation-for="IdCategoria" class="text-danger"></span>
                    </div>
                    <div class="col-6">
                        <label for="stockQuantity" class="form-label">Stock inicial</label>
                        <input type="number" name="stockQuantity" class="form-control" value="0" min="0" />
                    </div>
                </div>
            </div>
            <div class="form-section">
                <p class="form-section-title">Estado</p>
                <div class="form-check">
                    <input asp-for="Activo" class="form-check-input" />
                    <label asp-for="Activo" class="form-check-label">Producto activo</label>
                </div>
            </div>
            <div class="form-actions">
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
                <button type="submit" class="btn btn-primary">Guardar producto</button>
            </div>
        </form>
    </div>
</div>