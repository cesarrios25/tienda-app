@model TiendaApp.Models.Producto

@{
    ViewData["Title"] = "Editar Producto";
}

<h2>Editar Producto</h2>

<form asp-action="Edit" asp-controller="Producto" method="post">
    <input asp-for="IdProducto" type="hidden" />
    <input asp-for="CreadoEn" type="hidden" />
    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="NombreProducto" class="form-label"></label>
            <input asp-for="NombreProducto" class="form-control" />
            <span asp-validation-for="NombreProducto" class="text-danger"></span>
        </div>
        <div class="col-md-6 mb-3">
            <label asp-for="SKU" class="form-label"></label>
            <input asp-for="SKU" class="form-control" />
        </div>
    </div>
    <div class="mb-3">
        <label asp-for="DescripcionProducto" class="form-label"></label>
        <textarea asp-for="DescripcionProducto" class="form-control"></textarea>
    </div>
    <div class="row">
        <div class="col-md-4 mb-3">
            <label asp-for="Precio" class="form-label"></label>
            <input asp-for="Precio" class="form-control" />
        </div>
        <div class="col-md-4 mb-3">
            <label asp-for="DescuentoPrecio" class="form-label"></label>
            <input asp-for="DescuentoPrecio" class="form-control" />
        </div>
        <div class="col-md-4 mb-3">
            <label asp-for="Marca" class="form-label"></label>
            <input asp-for="Marca" class="form-control" />
        </div>
    </div>
    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="IdCategoria" class="form-label">Categoría</label>
            <select asp-for="IdCategoria" asp-items="ViewBag.CategoryId" class="form-select"></select>
        </div>
        <div class="col-md-6 mb-3">
            <label for="stockQuantity" class="form-label">Stock</label>
            <input type="number" name="stockQuantity" class="form-control"
                   value="@Model.Stock?.Cantidad" min="0" />
        </div>
    </div>
    <div class="mb-3 form-check">
        <input asp-for="Activo" class="form-check-input" />
        <label asp-for="Activo" class="form-check-label"></label>
    </div>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
    <button type="submit" class="btn btn-primary">Guardar</button>
</form>